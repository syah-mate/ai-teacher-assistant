# MongoDB Configuration
# Local development: mongodb://localhost:27017/ai-asisten-guru
# Production: Use MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/ai-asisten-guru

# JWT Secret for session encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_with_random_string

# Gemini AI API Key
# Get your free API key from: https://ai.google.dev/
# Steps:
# 1. Visit https://ai.google.dev/
# 2. Click "Get API Key in Google AI Studio"
# 3. Sign in with your Google account
# 4. Click "Create API Key" or "Get API Key"
# 5. Copy the key and paste it below
# Free tier limits: 60 requests/minute, 1500 requests/day
GEMINI_API_KEY=

# Gemini Model Selection
# Choose model based on your needs:
# - gemini-1.5-flash (recommended for free tier - fast & efficient)
# - gemini-1.5-flash-latest (always latest 1.5 flash version)
# - gemini-1.5-pro (more capable, slower, free tier)
# - gemini-2.0-flash-exp (experimental, may require paid tier)
# See available models: https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-1.5-flash

# Google Drive API Key (Optional - for future file upload features)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_API_KEY=

# Application URL
# Development: http://localhost:5173
# Production: Your deployed domain (e.g., https://yourapp.com)
PUBLIC_APP_URL=http://localhost:5173

# Environment (development or production)
NODE_ENV=development
